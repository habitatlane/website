---
/**
 * ImpactBand — full-bleed stat band.
 * NOTE: figures are PLACEHOLDERS pulled from site.impact (TODO: verify).
 */
import { site } from '../../data/site';

interface StatContent {
  value?: string;
  label?: string;
}

interface Props {
  heading?: string;
  stats?: StatContent[];
  note?: string;
}

const fallbackStats = [
  { value: `${site.impact.homesBuilt}+`, label: 'homes built' },
  { value: `${site.impact.repairs}+`, label: 'home repairs completed' },
  { value: `${new Date().getFullYear() - site.impact.sinceYear}`, label: 'years serving Lane County' },
];
const textOr = (value: string | undefined, fallback: string) => value?.trim() || fallback;
const withFallbackStat = (stat: StatContent, index: number) => {
  const fallback = fallbackStats[index] ?? fallbackStats[0];

  return {
    value: textOr(stat.value, fallback.value),
    label: textOr(stat.label, fallback.label),
  };
};

const { heading, stats: cmsStats = [], note } = Astro.props;

const content = {
  heading: textOr(heading, `Our impact since ${site.impact.sinceYear}`),
  stats: cmsStats.length ? cmsStats.map(withFallbackStat) : fallbackStats,
  note: textOr(note, 'Figures are approximate and being verified.'),
};
---

<section class="impact" aria-labelledby="impact-heading">
  <div class="container">
    <h2 id="impact-heading" class="impact-heading">
      {content.heading}
    </h2>
    <dl class="impact-grid">
      {
        content.stats.map((s) => (
          <div class="impact-item">
            <dt class="impact-value">{s.value}</dt>
            <dd class="impact-label">{s.label}</dd>
          </div>
        ))
      }
    </dl>
    <p class="impact-note">
      {content.note}
    </p>
  </div>
</section>

<style>
  .impact {
    background: var(--color-brand-accent);
    color: var(--color-white);
    padding-block: var(--space-8);
  }
  .impact-heading {
    color: var(--color-white);
    text-align: center;
    margin-bottom: var(--space-6);
  }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin: 0;
  }
  .impact-item {
    text-align: center;
  }
  .impact-value {
    font-size: var(--font-size-4xl);
    font-weight: var(--weight-bold);
    line-height: 1;
  }
  .impact-label {
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-lg);
  }
  .impact-note {
    text-align: center;
    margin: var(--space-6) 0 0;
    font-size: var(--font-size-xs);
    opacity: 0.85;
  }
  @media (max-width: 700px) {
    .impact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
