---
/**
 * HowWeHelp — three-card row summarizing the affiliate's core programs.
 * Inline SVG icons are decorative (aria-hidden); each card is a real link.
 */
import { withBase } from '../../utils/url';

const fallbackPrograms = [
  {
    title: 'Homeownership',
    href: '/get-help/homeownership/',
    external: false,
    body: 'We partner with families to build and buy affordable homes through sweat equity and an affordable mortgage.',
    icon: 'home',
  },
  {
    title: 'Minor Home Repair',
    href: '/get-help/minor-home-repair/',
    external: false,
    body: 'Critical repairs and accessibility improvements help neighbors stay safe in the homes they already own.',
    icon: 'wrench',
  },
  {
    title: 'ReStore',
    href: 'https://habitatlane.org/restore/',
    external: true,
    body: 'Shop or donate gently used furniture, appliances, and building materials. Every purchase funds our mission.',
    icon: 'store',
  },
] as const;

// Decorative inline icons (stroke = currentColor). Kept tiny and local.
const icons: Record<string, string> = {
  home: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="100%" height="100%"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10v10h14V10"/><path d="M9.5 20v-6h5v6"/></svg>',
  wrench: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="100%" height="100%"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-.5-.5-2.5 2.5-2.5Z"/></svg>',
  store: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="100%" height="100%"><path d="M3 9l1.5-5h15L21 9"/><path d="M3 9v0a3 3 0 0 0 6 0 3 3 0 0 0 6 0 3 3 0 0 0 6 0"/><path d="M5 9.5V20h14V9.5"/><path d="M9 20v-5h6v5"/></svg>',
};
const icon = (name: string) => icons[name] ?? '';
---

<section class="section how" aria-labelledby="how-heading">
  <div class="container">
    <p class="eyebrow">How we help</p>
    <h2 id="how-heading">Three ways we build community</h2>
    <div class="how-grid">
      {
        fallbackPrograms.map((p) => (
          <a
            class="card"
            href={p.external ? p.href : withBase(p.href)}
            target={p.external ? '_blank' : undefined}
            rel={p.external ? 'noopener noreferrer' : undefined}
          >
            <span class="card-icon" aria-hidden="true" set:html={icon(p.icon)} />
            <h3>
              {p.title}
              {p.external && <span class="sr-only"> (opens in a new tab)</span>}
            </h3>
            <p>{p.body}</p>
            <span class="card-more">Learn more -></span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-6);
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease,
      border-color 0.12s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-brand-accent);
    color: var(--color-text);
  }
  .card-icon {
    display: inline-flex;
    width: 48px;
    height: 48px;
    color: var(--color-brand-accent);
  }
  .card h3 {
    margin: 0;
    color: var(--color-brand);
  }
  .card p {
    margin: 0;
    color: var(--color-text);
    font-size: var(--font-size-sm);
  }
  .card-more {
    margin-top: auto;
    font-weight: var(--weight-semibold);
    color: var(--color-brand-accent);
  }

  @media (max-width: 820px) {
    .how-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
