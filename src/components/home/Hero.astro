---
/**
 * Hero — mission-first homepage hero.
 * Photo is a clearly-marked placeholder (TODO: drop in a real build-site
 * photo with descriptive alt text). CTAs are real text links, never
 * images-of-text.
 */
import Button from '../Button.astro';
import { site } from '../../data/site';
import { renderMarkdown } from '../../utils/markdown';
import { withBase } from '../../utils/url';

interface CtaContent {
  label?: string;
  url?: string;
  external?: boolean;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  primaryCta?: CtaContent;
  secondaryCta?: CtaContent;
  serviceText?: string;
  image?: string;
  imageAlt?: string;
}

const textOr = (value: string | undefined, fallback: string) => value?.trim() || fallback;
const ctaOr = (cta: CtaContent | undefined, fallback: Required<CtaContent>) => ({
  label: textOr(cta?.label, fallback.label),
  url: textOr(cta?.url, fallback.url),
  external: cta?.external ?? fallback.external,
});

const {
  eyebrow,
  heading,
  body,
  primaryCta,
  secondaryCta,
  serviceText,
  image,
  imageAlt,
} = Astro.props;

const content = {
  eyebrow: textOr(eyebrow, 'Habitat for Humanity of Central Lane'),
  heading: textOr(heading, 'Everyone deserves a safe, affordable place to call home.'),
  body: textOr(body, site.mission),
  primaryCta: ctaOr(primaryCta, { label: 'Donate', url: '/give/donate/', external: false }),
  secondaryCta: ctaOr(secondaryCta, {
    label: 'Volunteer',
    url: '/get-involved/volunteer/',
    external: false,
  }),
  serviceText: textOr(serviceText, `Serving ${site.serviceArea}`),
  image: image?.trim() ? withBase(image.trim()) : undefined,
  imageAlt: textOr(imageAlt, 'Habitat for Humanity of Central Lane build-site photo'),
};

const bodyHtml = await renderMarkdown(content.body);
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.heading}</h1>
      <div class="hero-mission" set:html={bodyHtml} />
      <div class="hero-ctas">
        <Button href={content.primaryCta.url} external={content.primaryCta.external} variant="primary" size="lg">
          {content.primaryCta.label}
        </Button>
        <Button href={content.secondaryCta.url} external={content.secondaryCta.external} variant="secondary" size="lg">
          {content.secondaryCta.label}
        </Button>
      </div>
      <p class="hero-service">{content.serviceText}</p>
    </div>

    {
      content.image ? (
        <img class="hero-photo hero-photo--image" src={content.image} alt={content.imageAlt} loading="eager" decoding="async" />
      ) : (
        <div class="hero-photo" role="img" aria-label="Placeholder for a Habitat build-site photo">
          <span class="hero-photo__label">Photo placeholder</span>
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-bg-subtle), var(--color-white));
    padding-block: var(--space-9);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: var(--space-8);
  }
  .hero-copy h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-4);
  }
  .hero-mission {
    font-family: var(--font-serif);
    font-size: var(--font-size-xl);
    color: var(--color-text);
    max-width: 38ch;
  }
  .hero-mission :global(p:last-child) {
    margin-bottom: 0;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block: var(--space-5);
  }
  .hero-service {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .hero-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    background:
      repeating-linear-gradient(
        45deg,
        rgba(0, 175, 215, 0.08),
        rgba(0, 175, 215, 0.08) 14px,
        rgba(196, 214, 0, 0.1) 14px,
        rgba(196, 214, 0, 0.1) 28px
      );
    border: 2px dashed var(--color-border);
    display: grid;
    place-items: center;
  }
  .hero-photo--image {
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
    display: block;
  }
  .hero-photo__label {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    background: var(--color-white);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 880px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-copy h1 {
      font-size: var(--font-size-3xl);
    }
    .hero-photo {
      order: -1;
    }
  }
</style>
