---
/**
 * Newsletter — signup placeholder.
 * TODO: wire `action` to the real provider (Mailchimp/Constant Contact/etc.)
 * endpoint. Until then the form is inert (action="#") and clearly labeled.
 */
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  formAction?: string;
  emailLabel?: string;
  emailPlaceholder?: string;
  buttonLabel?: string;
  note?: string;
}

const textOr = (value: string | undefined, fallback: string) => value?.trim() || fallback;
const {
  eyebrow,
  heading,
  body,
  formAction,
  emailLabel,
  emailPlaceholder,
  buttonLabel,
  note,
} = Astro.props;

const content = {
  eyebrow: textOr(eyebrow, 'Stay in the loop'),
  heading: textOr(heading, 'Get build news, events & ways to help'),
  body: textOr(
    body,
    'A short, occasional email from Habitat for Humanity of Central Lane. No spam, unsubscribe anytime.',
  ),
  formAction: textOr(formAction, '#'),
  emailLabel: textOr(emailLabel, 'Email address'),
  emailPlaceholder: textOr(emailPlaceholder, 'you@example.com'),
  buttonLabel: textOr(buttonLabel, 'Sign up'),
  note: textOr(note, 'Placeholder form - newsletter provider not yet connected.'),
};
---

<section class="section newsletter" aria-labelledby="newsletter-heading">
  <div class="container newsletter-inner">
    <div class="newsletter-copy">
      <p class="eyebrow">{content.eyebrow}</p>
      <h2 id="newsletter-heading">{content.heading}</h2>
      <p>{content.body}</p>
    </div>

    <!-- TODO: replace action="#" with the real newsletter form endpoint. -->
    <form class="newsletter-form" action={content.formAction} method="post" aria-describedby="newsletter-note">
      <div class="field">
        <label for="newsletter-email">{content.emailLabel}</label>
        <input
          type="email"
          id="newsletter-email"
          name="email"
          placeholder={content.emailPlaceholder}
          autocomplete="email"
          required
        />
      </div>
      <button type="submit" class="btn btn--primary btn--md">{content.buttonLabel}</button>
      <p id="newsletter-note" class="newsletter-note">
        {content.note}
      </p>
    </form>
  </div>
</section>

<style>
  .newsletter {
    background: var(--color-bg-subtle);
  }
  .newsletter-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .newsletter-form {
    display: grid;
    gap: var(--space-3);
  }
  .field {
    display: grid;
    gap: var(--space-2);
  }
  .field label {
    font-weight: var(--weight-semibold);
    font-size: var(--font-size-sm);
  }
  .field input {
    font: inherit;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-white);
  }
  /* Reuse the shared .btn classes from Button styling. */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-pill);
    border: 2px solid transparent;
    cursor: pointer;
    font-size: var(--font-size-base);
    padding: 0.7rem 1.4rem;
  }
  .btn--primary {
    background: var(--color-action);
    color: var(--color-white);
  }
  .btn--primary:hover {
    background: var(--color-action-hover);
  }
  .newsletter-note {
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }
  @media (max-width: 760px) {
    .newsletter-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
