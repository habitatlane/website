---
/**
 * EventsStrip — CMS-driven list of the next few upcoming events.
 * Receives an already-filtered/sorted array from the homepage.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  events: CollectionEntry<'events'>[];
}
const { events } = Astro.props;

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { weekday: 'short', month: 'short', day: 'numeric' }).format(d);
const fmtTime = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { hour: 'numeric', minute: '2-digit' }).format(d);
---

<section class="section events" aria-labelledby="events-heading">
  <div class="container">
    <div class="events-head">
      <div>
        <p class="eyebrow">Upcoming</p>
        <h2 id="events-heading">Events &amp; ways to show up</h2>
      </div>
      <a class="events-all" href="/events/">All events →</a>
    </div>

    {
      events.length === 0 ? (
        <p class="events-empty">No upcoming events right now — check back soon.</p>
      ) : (
        <ul class="events-list">
          {events.map((e) => (
            <li class="event">
              <div class="event-date" aria-hidden="true">
                <span class="event-month">
                  {new Intl.DateTimeFormat('en-US', { month: 'short' }).format(e.data.start)}
                </span>
                <span class="event-day">
                  {new Intl.DateTimeFormat('en-US', { day: 'numeric' }).format(e.data.start)}
                </span>
              </div>
              <div class="event-body">
                <h3 class="event-title">{e.data.title}</h3>
                <p class="event-meta">
                  <time datetime={e.data.start.toISOString()}>
                    {fmtDate(e.data.start)} · {fmtTime(e.data.start)}
                  </time>
                  {e.data.location && <span> · {e.data.location}</span>}
                </p>
                <p class="event-summary">{e.data.summary}</p>
                {e.data.registrationUrl && (
                  <a class="event-link" href={e.data.registrationUrl} target="_blank" rel="noopener noreferrer">
                    Register / details<span class="sr-only"> for {e.data.title} (opens in a new tab)</span> →
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>

<style>
  .events-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .events-all {
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }
  .events-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .event {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-white);
  }
  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    color: var(--color-brand);
  }
  .event-month {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
  }
  .event-day {
    font-size: var(--font-size-2xl);
    font-weight: var(--weight-bold);
    line-height: 1;
  }
  .event-title {
    margin: 0 0 var(--space-1);
    font-size: var(--font-size-lg);
  }
  .event-meta {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
  .event-summary {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-sm);
  }
  .event-link {
    font-weight: var(--weight-semibold);
    font-size: var(--font-size-sm);
  }
  .events-empty {
    color: var(--color-text-muted);
  }
  @media (max-width: 560px) {
    .event {
      grid-template-columns: 60px 1fr;
    }
  }
</style>
