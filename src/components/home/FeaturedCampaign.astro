---
/**
 * FeaturedCampaign — single CMS-driven featured campaign slot.
 * Receives the rendered campaign entry from the homepage. Renders nothing
 * if there is no featured campaign, so the homepage degrades gracefully
 * before any content exists.
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import Button from '../Button.astro';

interface Props {
  campaign?: CollectionEntry<'campaigns'>;
}
const { campaign } = Astro.props;

let Body: Awaited<ReturnType<typeof render>>['Content'] | null = null;
if (campaign) {
  const rendered = await render(campaign);
  Body = rendered.Content;
}

const data = campaign?.data;
const pct =
  data?.goalAmount && data?.raisedAmount
    ? Math.min(100, Math.round((data.raisedAmount / data.goalAmount) * 100))
    : null;
const money = (n: number) =>
  new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
---

{
  campaign && data && (
    <section class="section campaign" aria-labelledby="campaign-heading">
      <div class="container campaign-inner">
        <div class="campaign-media" role="img" aria-label={data.imageAlt ?? `${data.title} campaign image placeholder`}>
          {/* TODO: render data.image with <Image> once campaign images are uploaded via /admin. */}
          <span class="campaign-media__label">Campaign image</span>
        </div>
        <div class="campaign-copy">
          <p class="eyebrow">Featured campaign</p>
          <h2 id="campaign-heading">{data.title}</h2>
          <p class="campaign-summary">{data.summary}</p>

          {pct !== null && data.goalAmount && data.raisedAmount && (
            <div class="campaign-progress">
              <div class="bar" role="progressbar" aria-valuenow={pct} aria-valuemin={0} aria-valuemax={100} aria-label="Campaign progress">
                <span style={`width:${pct}%`} />
              </div>
              <p class="campaign-figures">
                <strong>{money(data.raisedAmount)}</strong> raised of {money(data.goalAmount)} goal ({pct}%)
              </p>
            </div>
          )}

          {Body && (
            <div class="prose campaign-body">
              <Body />
            </div>
          )}

          <Button href={data.ctaUrl} variant="primary" size="lg">{data.ctaLabel}</Button>
        </div>
      </div>
    </section>
  )
}

<style>
  .campaign-inner {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-7);
    align-items: center;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
  }
  .campaign-media {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-bright-blue), var(--color-habitat-green));
    display: grid;
    place-items: center;
    color: var(--color-white);
  }
  .campaign-media__label {
    font-weight: var(--weight-semibold);
    background: rgba(0, 0, 0, 0.18);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
  }
  .campaign-summary {
    font-family: var(--font-serif);
    font-size: var(--font-size-lg);
  }
  .campaign-progress {
    margin-block: var(--space-4);
  }
  .bar {
    height: 14px;
    border-radius: var(--radius-pill);
    background: var(--color-border);
    overflow: hidden;
  }
  .bar span {
    display: block;
    height: 100%;
    background: var(--color-action);
  }
  .campaign-figures {
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-sm);
  }
  .campaign-body {
    font-size: var(--font-size-base);
  }
  .campaign-body :global(p) {
    font-size: var(--font-size-base);
  }

  @media (max-width: 820px) {
    .campaign-inner {
      grid-template-columns: 1fr;
      padding: var(--space-5);
    }
  }
</style>
