---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="section cms-page">
  <div class="container cms-page-inner">
    <header class="cms-page-header">
      <h1>{title}</h1>
      {description && <p class="cms-page-description prose">{description}</p>}
    </header>
    <div class="cms-page-body prose">
      <slot />
    </div>
  </div>
</section>

<style>
  .cms-page-inner {
    max-width: 820px;
  }

  .cms-page-header {
    margin-bottom: var(--space-6);
  }

  .cms-page-description {
    color: var(--color-text-muted);
    font-size: var(--font-size-xl);
    line-height: var(--line-relaxed);
    margin-bottom: 0;
  }

  .cms-page-body :global(h2),
  .cms-page-body :global(h3) {
    margin-top: var(--space-7);
  }

  .cms-page-body :global(ul),
  .cms-page-body :global(ol) {
    margin-block: 0 var(--space-4);
    padding-left: var(--space-6);
  }

  .cms-page-body :global(li + li) {
    margin-top: var(--space-2);
  }
</style>
