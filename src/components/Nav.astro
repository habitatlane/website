---
/**
 * Nav — global site header: logo, primary navigation (IA from
 * `src/data/navigation.ts`), and a persistent Donate button.
 *
 * Cleanly separable for extraction into @habitat/ui: it depends only on the
 * navigation data module, the Button component, design tokens, and the logo
 * asset. Desktop dropdowns are CSS-only (hover + focus-within, no JS); the
 * mobile menu uses a tiny progressive-enhancement script.
 */
import { Image } from 'astro:assets';
import { mainNav, donateLink } from '../data/navigation';
import { site } from '../data/site';
import Button from './Button.astro';
import { pathWithoutBase, withBase } from '../utils/url';
import logo from '../assets/logo-central-lane-oneline-white.svg';

// Mark the current top-level item as active for aria-current.
const pathname = pathWithoutBase(Astro.url.pathname);
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBase('/')} class="brand" aria-label={`${site.name} — home`}>
      <Image
        src={logo}
        alt="Habitat for Humanity of Central Lane"
        widths={[240, 360]}
        sizes="(max-width: 600px) 200px, 240px"
        class="brand-logo"
        loading="eager"
      />
    </a>

    <button
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle menu"
    >
      <span class="menu-toggle__bars" aria-hidden="true"></span>
      <span>Menu</span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        {
          mainNav.map((group) => (
            <li class:list={['nav-item', { 'has-children': group.children }]}>
              <a
                href={group.href ? withBase(group.href) : undefined}
                class="nav-link"
                aria-current={group.href && isActive(group.href) ? 'page' : undefined}
              >
                {group.label}
                {group.children && <span class="caret" aria-hidden="true">▾</span>}
              </a>
              {group.children && (
                <ul class="submenu">
                  {group.children.map((child) => (
                    <li>
                      <a
                        href={child.external ? child.href : withBase(child.href)}
                        class="submenu-link"
                        target={child.external ? '_blank' : undefined}
                        rel={child.external ? 'noopener noreferrer' : undefined}
                      >
                        {child.label}
                        {child.external && <span class="sr-only"> (opens in a new tab)</span>}
                        {child.comingSoon && <span class="badge">soon</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
      <div class="nav-cta">
        <Button href={donateLink.href} variant="primary">Donate</Button>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg-invert);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 76px;
  }
  .brand {
    display: inline-flex;
    flex-shrink: 0;
  }
  .brand-logo {
    width: auto;
    height: 44px;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-item {
    position: relative;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-weight: var(--weight-medium);
    color: var(--color-text-invert);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover,
  .nav-link[aria-current='page'] {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-text-invert);
  }
  .caret {
    font-size: 0.7em;
  }

  .submenu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 220px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.12s ease,
      transform 0.12s ease;
  }
  /* Desktop: reveal on hover or keyboard focus (no JS needed). */
  .has-children:hover .submenu,
  .has-children:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .submenu-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-sm);
  }
  .submenu-link:hover {
    background: var(--color-bg-subtle);
    color: var(--color-brand);
  }
  .badge {
    font-size: 0.65rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cool-gray);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 1px 7px;
  }

  .menu-toggle {
    display: none;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    font: inherit;
    font-weight: var(--weight-medium);
    color: var(--color-text-invert);
    cursor: pointer;
  }
  .menu-toggle__bars,
  .menu-toggle__bars::before,
  .menu-toggle__bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    position: relative;
  }
  .menu-toggle__bars::before {
    position: absolute;
    top: -6px;
  }
  .menu-toggle__bars::after {
    position: absolute;
    top: 6px;
  }

  /* --- Mobile --- */
  @media (max-width: 900px) {
    .menu-toggle {
      display: inline-flex;
    }
    .primary-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-3);
      background: var(--color-bg-invert);
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: var(--shadow-md);
      padding: var(--space-4) var(--container-pad) var(--space-6);
      display: none;
    }
    .primary-nav.is-open {
      display: flex;
    }
    .nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
    .nav-link {
      padding: var(--space-3);
      font-size: var(--font-size-lg);
    }
    .submenu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: none;
      border-left: 2px solid var(--color-border);
      border-radius: 0;
      margin-left: var(--space-3);
    }
    .nav-cta :global(.btn) {
      width: 100%;
    }
  }
</style>

<script>
  // Progressive enhancement: toggle the mobile menu.
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
  });
</script>
