---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSections from '../components/HomeSections.astro';

type HomeSection = CollectionEntry<'home'>['data']['sections'][number];

const defaultSections = [
  { type: 'hero' },
  { type: 'howWeHelp', programs: [] },
  { type: 'impactBand', stats: [] },
  { type: 'featuredCampaign' },
  { type: 'eventsStrip' },
  { type: 'newsletter' },
] satisfies HomeSection[];

// --- CMS-driven content ---
// Featured campaign: the first non-draft entry flagged `featured`.
const campaigns = await getCollection('campaigns', (c) => !c.data.draft);
const featuredCampaign = campaigns.find((c) => c.data.featured);

// Events: next few upcoming, soonest first.
const now = new Date();
const events = (await getCollection('events', (e) => !e.data.draft))
  .filter((e) => (e.data.end ?? e.data.start) >= now)
  .sort((a, b) => a.data.start.getTime() - b.data.start.getTime())
  .slice(0, 3);

const homeEntries = await getCollection('home');
const home = homeEntries.find((entry) => entry.id === 'index') ?? homeEntries[0];
const sections = home?.data.sections.length ? home.data.sections : defaultSections;
---

<BaseLayout
  title="Home"
  description="Habitat for Humanity of Central Lane brings people together to build homes, community, and hope across Lane County, Oregon."
>
  <HomeSections sections={sections} featuredCampaign={featuredCampaign} events={events} />
</BaseLayout>
