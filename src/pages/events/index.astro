---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { withBase } from '../../utils/url';

const events = await getCollection('events', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const now = new Date();
const upcomingEvents = events
  .filter((event) => (event.data.end ?? event.data.start) >= now)
  .sort((a, b) => a.data.start.getTime() - b.data.start.getTime());
const pastEvents = events
  .filter((event) => (event.data.end ?? event.data.start) < now)
  .sort((a, b) => b.data.start.getTime() - a.data.start.getTime());

const fmtDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
const fmtTime = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    hour: 'numeric',
    minute: '2-digit',
  }).format(date);
const fmtEventDate = (start: Date, end?: Date) => {
  const startText = `${fmtDate(start)} · ${fmtTime(start)}`;
  return end ? `${startText} - ${fmtTime(end)}` : startText;
};
---

<BaseLayout
  title="Events"
  description="Upcoming Habitat for Humanity of Central Lane events, volunteer opportunities, and community gatherings."
>
  <section class="section events-hero">
    <div class="container events-hero-inner">
      <p class="eyebrow">Events</p>
      <h1>Ways to show up, learn, and celebrate.</h1>
      <p class="events-intro prose">
        Join Habitat staff, volunteers, partner families, and neighbors at build
        orientations, dedication events, ReStore opportunities, and community gatherings.
      </p>
    </div>
  </section>

  <section class="section events-list-section" aria-labelledby="upcoming-events-heading">
    <div class="container">
      <div class="events-section-head">
        <p class="eyebrow">Upcoming</p>
        <h2 id="upcoming-events-heading">Upcoming Events</h2>
      </div>
      {
        upcomingEvents.length === 0 ? (
          <p class="events-empty">No upcoming events right now. Check back soon.</p>
        ) : (
          <ul class="events-list">
            {upcomingEvents.map((event) => (
              <li>
                <article class="event-card">
                  <div class="event-date" aria-hidden="true">
                    <span class="event-month">
                      {new Intl.DateTimeFormat('en-US', { month: 'short' }).format(event.data.start)}
                    </span>
                    <span class="event-day">
                      {new Intl.DateTimeFormat('en-US', { day: 'numeric' }).format(event.data.start)}
                    </span>
                  </div>
                  <div class="event-body">
                    <h3>
                      <a href={withBase(`/events/${event.id}/`)}>{event.data.title}</a>
                    </h3>
                    <p class="event-meta">
                      <time datetime={event.data.start.toISOString()}>
                        {fmtEventDate(event.data.start, event.data.end)}
                      </time>
                      {event.data.location && <span> · {event.data.location}</span>}
                    </p>
                    <p class="event-summary">{event.data.summary}</p>
                    <Button href={`/events/${event.id}/`} variant="outline">Event details</Button>
                  </div>
                </article>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  {
    pastEvents.length > 0 && (
      <section class="section past-events-section" aria-labelledby="past-events-heading">
        <div class="container">
          <div class="events-section-head">
            <p class="eyebrow">Past</p>
            <h2 id="past-events-heading">Past Events</h2>
          </div>
          <ul class="events-list events-list-compact">
            {pastEvents.map((event) => (
              <li>
                <article class="event-card">
                  <div class="event-date" aria-hidden="true">
                    <span class="event-month">
                      {new Intl.DateTimeFormat('en-US', { month: 'short' }).format(event.data.start)}
                    </span>
                    <span class="event-day">
                      {new Intl.DateTimeFormat('en-US', { day: 'numeric' }).format(event.data.start)}
                    </span>
                  </div>
                  <div class="event-body">
                    <h3>
                      <a href={withBase(`/events/${event.id}/`)}>{event.data.title}</a>
                    </h3>
                    <p class="event-meta">
                      <time datetime={event.data.start.toISOString()}>
                        {fmtEventDate(event.data.start, event.data.end)}
                      </time>
                      {event.data.location && <span> · {event.data.location}</span>}
                    </p>
                    <p class="event-summary">{event.data.summary}</p>
                    <Button href={`/events/${event.id}/`} variant="outline">Event details</Button>
                  </div>
                </article>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .events-hero {
    background: var(--color-bg-subtle);
  }

  .events-hero-inner {
    max-width: 820px;
  }

  .events-intro {
    color: var(--color-text-muted);
    font-size: var(--font-size-xl);
    line-height: var(--line-relaxed);
    margin-bottom: 0;
  }

  .events-list-section {
    padding-top: var(--space-7);
  }

  .past-events-section {
    padding-top: 0;
  }

  .events-section-head {
    margin-bottom: var(--space-5);
  }

  .events-list {
    display: grid;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .event-card {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 76px;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    color: var(--color-brand);
  }

  .event-month {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
  }

  .event-day {
    font-size: var(--font-size-2xl);
    font-weight: var(--weight-bold);
    line-height: 1;
  }

  .event-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .event-body h3 {
    margin-bottom: var(--space-1);
  }

  .event-body h3 a {
    color: inherit;
    text-decoration: none;
  }

  .event-body h3 a:hover {
    color: var(--color-brand-accent);
  }

  .event-meta {
    margin-bottom: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .event-summary {
    color: var(--color-text-muted);
  }

  .events-empty {
    color: var(--color-text-muted);
  }

  @media (max-width: 560px) {
    .event-card {
      grid-template-columns: 60px 1fr;
    }
  }
</style>
