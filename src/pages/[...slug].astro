---
/**
 * CMS-managed pages plus stub/"coming soon" pages for the information
 * architecture. CMS entries take precedence over placeholders with the same
 * slug, so editors can promote a page by adding Markdown under
 * `src/content/pages`.
 */
import { getCollection, render, type CollectionEntry, type RenderResult } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import CmsPage from '../components/CmsPage.astro';

type PageEntry = CollectionEntry<'pages'>;
type Stub = { slug: string; title: string; blurb?: string };
type RouteProps =
  | { kind: 'page'; page: PageEntry }
  | ({ kind: 'stub' } & Stub);

export async function getStaticPaths() {
  const stubs: Stub[] = [
    { slug: 'about', title: 'Our Story', blurb: 'Habitat for Humanity of Central Lane has been building homes, community, and hope since 1990. A fuller history is on the way.' },
    { slug: 'about/financials', title: 'Financials', blurb: 'Annual reports and financial statements will be posted here.' },
    { slug: 'contact', title: 'Contact' },

    { slug: 'get-help', title: 'Get Help' },
    { slug: 'get-help/homeownership', title: 'Homeownership', blurb: 'Learn about partnering with Habitat to build and buy an affordable home through sweat equity and an affordable mortgage.' },
    { slug: 'get-help/minor-home-repair', title: 'Minor Home Repair', blurb: 'Critical repairs and accessibility improvements that help neighbors stay safe at home.' },

    { slug: 'get-involved', title: 'Get Involved' },
    { slug: 'get-involved/volunteer', title: 'Volunteer', blurb: 'Build days, committees, and ReStore shifts — there’s a place for everyone.' },

    { slug: 'give', title: 'Give' },
    { slug: 'give/donate', title: 'Donate', blurb: 'Your gift builds homes and repairs across Lane County. Online giving is coming soon.' },
    { slug: 'give/ways-to-give', title: 'Ways to Give' },
    { slug: 'give/cars-for-homes', title: 'Cars for Homes', blurb: 'Donate a vehicle to support Habitat for Humanity of Central Lane.' },
    { slug: 'give/in-kind', title: 'In-Kind Gifts', blurb: 'Donate materials, services, and goods to support our mission.' },
  ];

  const pages = await getCollection('pages', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  const pageSlugs = new Set(pages.map((page) => page.id));
  const pagePaths = pages.map((page) => ({
    params: { slug: page.id },
    props: { kind: 'page', page } satisfies RouteProps,
  }));
  const stubPaths = stubs
    .filter((stub) => !pageSlugs.has(stub.slug))
    .map((stub) => ({
      params: { slug: stub.slug },
      props: { kind: 'stub', ...stub } satisfies RouteProps,
    }));

  return [...pagePaths, ...stubPaths];
}

const props = Astro.props as RouteProps;
const page = props.kind === 'page' ? props.page : undefined;
const stub = props.kind === 'stub' ? props : undefined;
const title = page ? page.data.title : stub?.title;
const description = page ? page.data.description : stub?.blurb;

let Content: RenderResult['Content'] | undefined;
if (page) {
  ({ Content } = await render(page));
}
---

<BaseLayout title={title} description={description}>
  {
    page && Content ? (
      <CmsPage title={page.data.title} description={page.data.description}>
        <Content />
      </CmsPage>
    ) : stub ? (
      <ComingSoon title={stub.title} blurb={stub.blurb} />
    ) : (
      null
    )
  }
</BaseLayout>
